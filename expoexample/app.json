{
  "expo": {
    "name": "expoexample",
    "slug": "expoexample",
    "owner": "shekhar-miri",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.miri.sdk-test"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.shekharmiri.expoexample"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "expoexample will use your photos to help you track your health and personalize your nutrition coaching."
        }
      ],
      "expo-web-browser",
      "expo-font",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.870681143575-hq4d642kbfp68f72qip5jk35acrhu0l5"
        }
      ]
    ],
    "extra": {
      "miriApiKey": "YOUR_MIRI_API_KEY",
      "googleIOSClientId": "YOUR_GOOGLE_IOS_CLIENT_ID",
      "firebaseProjectId": "YOUR_FIREBASE_PROJECT_ID",
      "authProvider": "google"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
